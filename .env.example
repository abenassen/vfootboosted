# Configurazione specifica della macchina. Copiare in .env (MAI committato).
# Il codice è identico su portatile e server: cambia solo questo file.

# --- Django ---------------------------------------------------------------
# Genera con: python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# In produzione la SPA è servita dalla stessa origine dell'API: lasciare vuoto.
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database -------------------------------------------------------------
# sqlite (default, sviluppo) | mysql | postgresql
DB_ENGINE=sqlite
# DB_NAME=vfoot
# DB_USER=vfoot
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306

# --- Pipeline dati --------------------------------------------------------
# Ogni quanti minuti al massimo si ri-scrapa la STESSA partita live.
# È la leva per adattare l'intensità alla macchina: alzarlo se il server soffre.
VFOOT_LIVE_POLL_MINUTES=2
# Radice di historical-data/ e data_fantacalcio/ (default: radice del repo).
# VFOOT_DATA_DIR=/percorso/dei/dati
